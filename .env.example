# Copy to `.env` and fill in. `.env` is gitignored -- never commit it.
#
# NEVER put real values in THIS file. It is a template and it is committed.
#
# Get these from: Supabase dashboard -> Project Settings -> Database / API.

# ---------------------------------------------------------------------------
# The ONLY value the migration scripts need.
# ---------------------------------------------------------------------------
# Dashboard -> Project Settings -> Database -> Connection string -> URI.
# Use the SESSION POOLER (port 5432) or DIRECT connection for migrations.
# Do NOT use the transaction pooler (port 6543) to run DDL -- it cannot hold
# the advisory locks and prepared statements that migrations rely on.
#
# Replace <password> with your database password, and DROP the square brackets
# Supabase shows around it. If the password contains any of  @ : / ? # [ ] %
# then percent-encode it -- an unescaped `@` terminates the userinfo section of
# the URI and the connection will fail with a confusing host error.
#   @ -> %40    : -> %3A    / -> %2F    # -> %23    % -> %25
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Needed later, by the app -- not by the schema scripts.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co

# Safe to expose to a browser. Subject to RLS.
SUPABASE_ANON_KEY=

# NEVER expose this. It BYPASSES row-level security entirely -- every policy in
# this project becomes decorative. Server-side only, and only where a request
# genuinely has no user identity (e.g. the pg_cron bid-close job).
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Local development cluster (scripts/db-test.sh). Not Supabase.
# The local cluster created by this project listens on 5433.
# ---------------------------------------------------------------------------
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=eworks
